# vim:fileencoding=utf-8:ft=conf:foldmethod=marker
# Fonts
font_family      monospace
# font_family      Fira Code Nerd Font 
italic_family    auto
bold_font        auto
bold_italic_font auto

font_size                         14

# Mouse
cursor_shape                      block
cursor_beam_thickness             1.25
cursor_blink_interval             0
click_interval 				      0
shell_integration                 no-cursor
focus_follows_mouse 		      no

# Performance
sync_to_monitor 			      no	

# Bell
enable_audio_bell 			      no

# Window
remember_window_size   		      no
background_opacity 			      0.95

map ctrl+shift+equal    	      increase_font_size
map ctrl+shift+minus    	      decrease_font_size
map ctrl+shift+backspace 	      restore_font_size
map ctrl+shift+f6     		      set_font_size 16.0

adjust_line_height  105%
window_margin_width 0
window_padding_width 1

symbol_map U+E5FA-U+E62B Symbols Nerd Font
# Devicons
symbol_map U+E700-U+E7C5 Symbols Nerd Font
# Font Awesome
symbol_map U+F000-U+F2E0 Symbols Nerd Font
# Font Awesome Extension
symbol_map U+E200-U+E2A9 Symbols Nerd Font
# Material Design Icons
symbol_map U+F500-U+FD46 Symbols Nerd Font
# Weather
symbol_map U+E300-U+E3EB Symbols Nerd Font
# Octicons
symbol_map U+F400-U+F4A8,U+2665,U+26A1,U+F27C Symbols Nerd Font
# Powerline Extra Symbols
symbol_map U+E0A3,U+E0B4-U+E0C8,U+E0CC-U+E0D2,U+E0D4 Symbols Nerd Font
# IEC Power Symbols
symbol_map U+23FB-U+23FE,U+2b58 Symbols Nerd Font
# Font Logos
symbol_map U+F300-U+F313 Symbols Nerd Font
# Pomicons
symbol_map U+E000-U+E00D Symbols Nerd Font

symbol_map U+f101-U+f208 nonicon

# BEGIN_KITTY_THEME
# Gruvbox Dark
include current-theme.conf
# END_KITTY_THEME
